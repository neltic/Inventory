{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./out-tsc/app",
        "rootDir": "src",
        "types": [],
        "paths": {
            "@models": [
                "./src/app/models/index.ts"
            ],
            "@services": [
                "./src/app/services/index.ts"
            ],
            "@core": [
                "./src/app/core/index.ts"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "src/**/*.spec.ts"
    ]
}