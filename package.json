{
  "name": "inventory",
  "version": "1.7.0",
  "scripts": {
    "prepare": "husky",
	"deploy:main": "git checkout main && git pull origin main && git merge develop && git push origin main && git checkout develop"
  },
  "author": "@neltic",
  "license": "MIT",
  "type": "commonjs",
  "homepage": "https://github.com/neltic/Inventory#readme",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "scope-empty": [2, "never"],
      "scope-enum": [2, "always", ["back", "front", "ci", "db", "auth"]],
      "subject-case": [2, "always", "lower-case"]
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7"
  }
}
